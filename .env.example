DATABASE_URL="mysql://quiz_user:quiz_password@127.0.0.1:3306/quiz_game"

# Stockage des médias : "local" (disque, par défaut) ou "s3" (Minio, nécessite `docker compose up -d`)
STORAGE_DRIVER=local
S3_ENDPOINT=http://127.0.0.1:9002
S3_PUBLIC_URL=http://127.0.0.1:9002
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=quiz-media

# Cache Redis pour la transformation d'images à la volée (nécessite `docker compose up -d`)
REDIS_URL=redis://127.0.0.1:6379
TRANSFORM_CACHE_TTL=3600
